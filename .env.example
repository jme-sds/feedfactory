OPENAI_BASE_URL="https://api.openai.com/v1" # replace with your openai compatible api base url
OPENAI_API_KEY="sk-your-secret-api-key" # replace with your provider api key
DEMO_MODE=false # set to "true" to hide AI Provider settings and require login
DEMO_USER=demo  # login username shown on the demo login page
DEMO_PASS=demo  # login password shown on the demo login page
